                    },
                    {
                        "OTIO_SCHEMA": "Clip.2",
                        "metadata": {
                            "bee_video": {
                                "narration": {
                                    "text": "First responders arrived at 10:28 PM. What they found was a scene that would take months to fully process.\n\nTwo weapons had been used — a shotgun for Paul, a rifle for Maggie. No casings were ever recovered."
                                },
                                "segment_id": "crime-scene-evidence"
                            }
                        },
                        "name": "Crime Scene Evidence — narration",
                        "source_range": {
                            "OTIO_SCHEMA": "TimeRange.1",
                            "duration": {
                                "OTIO_SCHEMA": "RationalTime.1",
                                "rate": 30.0,
                                "value": 456.0
                            },
                            "start_time": {
                                "OTIO_SCHEMA": "RationalTime.1",
                                "rate": 30.0,
                                "value": 0.0
                            }
                        },
                        "effects": [],
                        "markers": [],
                        "enabled": true,
                        "color": null,
                        "media_references": {
                            "DEFAULT_MEDIA": {
                                "OTIO_SCHEMA": "MissingReference.1",
                                "metadata": {},
                                "name": "",
                                "available_range": null,
                                "available_image_bounds": null
                            }
                        },
                        "active_media_reference_key": "DEFAULT_MEDIA"
                    },
                    {
                        "OTIO_SCHEMA": "Clip.2",
                        "metadata": {
                            "bee_video": {
                                "narration": {
                                    "text": "As investigators dug deeper, a web of financial crimes began to surface."
                                },
                                "segment_id": "ai-courtroom-visualization"
                            }
                        },
                        "name": "AI Courtroom Visualization — narration",
                        "source_range": {
                            "OTIO_SCHEMA": "TimeRange.1",
                            "duration": {
                                "OTIO_SCHEMA": "RationalTime.1",
                                "rate": 30.0,
                                "value": 144.0
                            },
                            "start_time": {
                                "OTIO_SCHEMA": "RationalTime.1",
                                "rate": 30.0,
                                "value": 0.0
                            }
                        },
                        "effects": [],
                        "markers": [],
                        "enabled": true,
                        "color": null,
                        "media_references": {
                            "DEFAULT_MEDIA": {
                                "OTIO_SCHEMA": "MissingReference.1",
                                "metadata": {},
                                "name": "",
                                "available_range": null,
                                "available_image_bounds": null
                            }
                        },
                        "active_media_reference_key": "DEFAULT_MEDIA"
                    },
                    {
                        "OTIO_SCHEMA": "Clip.2",
                        "metadata": {
                            "bee_video": {
                                "narration": {
                                    "text": "The Murdaugh family had dominated the legal landscape of Hampton County for over a century. Three generations of solicitors.\n\nBut beneath the veneer of Southern respectability lay a pattern of obstruction, influence, and unchecked power."
                                },
                                "segment_id": "narration-only"
                            }
                        },
                        "name": "Narration Only — narration",
                        "source_range": {
                            "OTIO_SCHEMA": "TimeRange.1",
                            "duration": {
                                "OTIO_SCHEMA": "RationalTime.1",
                                "rate": 30.0,
                                "value": 420.0
                            },
                            "start_time": {
                                "OTIO_SCHEMA": "RationalTime.1",
                                "rate": 30.0,
                                "value": 0.0
                            }
                        },
                        "effects": [],
                        "markers": [],
                        "enabled": true,
                        "color": null,
                        "media_references": {
                            "DEFAULT_MEDIA": {
                                "OTIO_SCHEMA": "MissingReference.1",
                                "metadata": {},
                                "name": "",
                                "available_range": null,
                                "available_image_bounds": null
                            }
                        },
                        "active_media_reference_key": "DEFAULT_MEDIA"
                    },
                    {
                        "OTIO_SCHEMA": "Clip.2",
                        "metadata": {
                            "bee_video": {
                                "narration": {
                                    "text": "The family portrait told one story. The evidence would tell another."
                                },
